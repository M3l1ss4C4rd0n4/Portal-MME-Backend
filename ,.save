import psycopg2
conn = psycopg2.connect(host='127.0.0.1', port=5432, dbname='portal_energetico', user='postgres')
cur = conn.cursor()

print('=== KPIs GLOBALES ===')
cur.execute('''
SELECT
  COUNT(DISTINCT nombre_proyecto_id) AS n_contratos,
  ROUND(AVG(avance) * 100, 1) AS avance_general,
  ROUND(
    SUM(CASE
      WHEN estado = 'Completo'
       AND necesaria_para_desembolso = 'Sí'
       AND desembolso IS NOT NULL
      THEN desembolso ELSE 0
    END) / NULLIF(COUNT(DISTINCT nombre_proyecto_id), 0) * 100, 1) AS avance_financiero
FROM contratos_or.seguimiento s
WHERE nro_desembolso IS NOT NULL
''')
row = cur.fetchone()
print('n_contratos:', row[0])
print('avance_general:', row[1], '% (Power BI 16.1%)')
print('avance_financiero:', row[2], '% (Power BI 50.0%)')

print()
print('=== POR PROYECTO ===')
cur.execute('''
SELECT
  s.nombre_proyecto_id, s.ejecutor,
  ROUND(AVG(s.avance) * 100, 1) AS avance_general,
  ROUND(SUM(CASE WHEN s.estado=\'Completo\' AND s.necesaria_para_desembolso=\'Si\' AND s.desembolso IS NOT NULL THEN s.desembolso ELSE 0 END) * 100, 1) AS avance_fin_si,
  ROUND(SUM(CASE WHEN s.estado=\'Completo\' AND s.necesaria_para_desembolso=\'Si\' AND s.desembolso IS NOT NULL THEN s.desembolso ELSE 0 END) * 100, 1) AS avance_fin_acento,
  COUNT(*) total_act
FROM contratos_or.seguimiento s
WHERE s.nro_desembolso IS NOT NULL
GROUP BY s.nombre_proyecto_id, s.ejecutor ORDER BY s.nombre_proyecto_id
''')
print('proyecto | ejecutor | av_gen | av_fin(Si) | total_act')
for r in cur.fetchall():
    print(r)
conn.close()
" 2>&1
