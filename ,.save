import psycopg2
conn = psycopg2.connect(host='127.0.0.1', port=5432, dbname='portal_energetico', user='postgres')
cur = conn.cursor()

print("=== COBERTURA MUNICIPAL — comunidades.base (implementadas) ===\n")

cur.execute("""
SELECT
  COUNT(*) AS total_implementadas,
  COUNT(municipio) AS con_municipio,
  COUNT(*) - COUNT(municipio) AS sin_municipio,
  COUNT(DISTINCT municipio) AS municipios_unicos,
  COUNT(latitud) AS con_latitud,
  COUNT(longitud) AS con_longitud
FROM comunidades.base
WHERE implementado = 'Si'
""")
row = cur.fetchone()
total, con_mun, sin_mun, mun_uniq, con_lat, con_lon = row
print(f"  Total implementadas       : {total}")
print(f"  Con municipio             : {con_mun} ({100*con_mun/total:.1f}%)")
print(f"  Sin municipio             : {sin_mun}")
print(f"  Municipios únicos         : {mun_uniq}")
print(f"  Con latitud               : {con_lat} ({100*con_lat/total:.1f}%)")
print(f"  Con longitud              : {con_lon} ({100*con_lon/total:.1f}%)")

print("\n=== IMPLEMENTADAS POR DEPARTAMENTO + MUNICIPIOS POR DEPTO ===\n")
cur.execute("""
SELECT
  departamento,
  COUNT(*) n_ces,
  COUNT(DISTINCT municipio) n_municipios,
  COUNT(CASE WHEN municipio IS NOT NULL THEN 1 END) ces_con_mun,
  ROUND(100.0 * COUNT(CASE WHEN municipio IS NOT NULL THEN 1 END) / COUNT(*), 1) pct_con_mun
FROM comunidades.base
WHERE implementado = 'Si'
GROUP BY departamento
ORDER BY n_ces DESC
""")
cols = [d[0] for d in cur.description]
print(f"  {'Departamento':25s} | {'CEs':>4s} | {'Muns':>4s} | {'c/mun':>5s} | {'%':>5s}")
print("  " + "-"*55)
for r in cur.fetchall():
    print(f"  {str(r[0]):25s} | {r[1]:>4d} | {r[2]:>4d} | {r[3]:>5d} | {float(r[4] or 0):>4.0f}%")

print("\n=== MUNICIPIOS CON MÁS CEs (TOP 20) ===\n")
cur.execute("""
SELECT departamento, municipio, COUNT(*) n_ces
FROM comunidades.base
WHERE implementado = 'Si' AND municipio IS NOT NULL
GROUP BY departamento, municipio
ORDER BY n_ces DESC
LIMIT 20
""")
print(f"  {'Departamento':25s} | {'Municipio':25s} | CEs")
print("  " + "-"*60)
for r in cur.fetchall():
    print(f"  {str(r[0]):25s} | {str(r[1]):25s} | {r[2]}")

print("\n=== MUESTRA DE COORDENADAS (primeras 10 con lat/lon) ===\n")
cur.execute("""
SELECT departamento, municipio, latitud, longitud
FROM comunidades.base
WHERE implementado = 'Si' AND latitud IS NOT NULL AND longitud IS NOT NULL
LIMIT 10
""")
for r in cur.fetchall():
    print(f"  {str(r[0]):20s} | {str(r[1]):20s} | lat={r[2]} | lon={r[3]}")

conn.close()
PYEOF
 cd /home/admonctrlxm/server && source venv/bin/activate && python3 -c "
import psycopg2
conn = psycopg2.connect(host='127.0.0.1', port=5432, dbname='portal_energetico', user='postgres')
cur = conn.cursor()

# Basic coverage
cur.execute('''
SELECT
  COUNT(*) total,
  COUNT(municipio) con_municipio,
  COUNT(DISTINCT municipio) municipios_unicos,
  COUNT(latitud) con_lat,
  COUNT(longitud) con_lon
FROM comunidades.base WHERE implementado=\'Si\'
''')
r = cur.fetchone()
print('COBERTURA:')
print(f'  total={r[0]}, con_municipio={r[1]} ({100*r[1]/r[0]:.1f}%), municipios_unicos={r[2]}, con_lat={r[3]} ({100*r[3]/r[0]:.1f}%)')

# Top municipios
cur.execute('''
SELECT departamento, municipio, COUNT(*) n
FROM comunidades.base
WHERE implementado=\'Si\' AND municipio IS NOT NULL
GROUP BY departamento, municipio ORDER BY n DESC LIMIT 15
''')
print()
print('TOP 15 MUNICIPIOS:')
for r in cur.fetchall(): print(f'  {str(r[1]):25s} ({str(r[0]):20s}): {r[2]} CEs')

# Muestra lat/lon
cur.execute('''
SELECT departamento, municipio, latitud, longitud
FROM comunidades.base
WHERE implementado=\'Si\' AND latitud IS NOT NULL AND latitud != \'\'
LIMIT 8
''')
print()
print('MUESTRA lat/lon:')
for r in cur.fetchall(): print(f'  {str(r[1]):20s} lat={r[2]} lon={r[3]}')

# Distribución de municipios por cantidad de CEs
cur.execute('''
SELECT n_ces, COUNT(*) n_municipios FROM (
  SELECT municipio, COUNT(*) n_ces
  FROM comunidades.base WHERE implementado=\'Si\' AND municipio IS NOT NULL
  GROUP BY municipio
) t GROUP BY n_ces ORDER BY n_ces
''')
print()
print('CEs por municipio (distribución):')
for r in cur.fetchall(): print(f'  {r[0]} CEs → {r[1]} municipios')

conn.close()
" 2>&1
