import psycopg2
conn = psycopg2.connect(host='127.0.0.1', port=5432, dbname='portal_energetico', user='postgres')
cur = conn.cursor()

# What municipality data exists?
cur.execute('''
SELECT 
  COUNT(*) total,
  COUNT(DISTINCT municipio) municipios_distintos,
  COUNT(CASE WHEN municipio IS NOT NULL AND municipio != '' THEN 1 END) con_municipio,
  COUNT(CASE WHEN latitud IS NOT NULL THEN 1 END) con_latitud,
  COUNT(CASE WHEN longitud IS NOT NULL THEN 1 END) con_longitud
FROM comunidades.base WHERE implementado = 'Si'
''')
r = cur.fetchone()
print('Total CEs implementadas:', r[0])
print('Municipios distintos:', r[1])
print('Con municipio:', r[2])
print('Con latitud:', r[3])
print('Con longitud:', r[4])

print()
cur.execute('''
SELECT municipio, departamento, COUNT(*) n
FROM comunidades.base WHERE implementado = 'Si' AND municipio IS NOT NULL
GROUP BY municipio, departamento ORDER BY n DESC LIMIT 20
''')
print('Top 20 municipios por CEs:')
for r in cur.fetchall():
    print(f'  {str(r[0]):35s} {str(r[1]):25s} n={r[2]}')

conn.close()
