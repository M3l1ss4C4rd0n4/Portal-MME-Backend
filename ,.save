import psycopg2
conn = psycopg2.connect(host='127.0.0.1', port=5432, dbname='portal_energetico', user='postgres')
cur = conn.cursor()

# Check all columns
cur.execute(\"SELECT column_name, data_type FROM information_schema.columns WHERE table_schema='comunidades' AND table_name='base' ORDER BY ordinal_position\")
print('=== COLUMNAS comunidades.base ===')
for r in cur.fetchall(): print(f'  {r[0]}: {r[1]}')

print()
# Check zona values
cur.execute(\"SELECT zona, implementado, COUNT(*) FROM comunidades.base GROUP BY zona, implementado ORDER BY zona, implementado\")
print('=== ZONA distribution ===')
for r in cur.fetchall(): print(f'  zona={repr(r[0])}, implementado={repr(r[1])}: {r[2]}')

print()
# Check tipo/tipo_comunidad values
cur.execute(\"SELECT COUNT(*), departamento, zona FROM comunidades.base WHERE implementado='Si' GROUP BY departamento, zona ORDER BY COUNT(*) DESC LIMIT 20\")
print('=== Top 20 departamento+zona combos (implementadas) ===')
for r in cur.fetchall(): print(f'  n={r[0]}, dept={r[1]}, zona={r[2]}')

conn.close()
